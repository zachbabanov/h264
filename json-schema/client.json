{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "description": "Client configuration",
  "properties": {
    "log": {
      "type": "object",
      "description": "Logging settings (optional)",
      "properties": {
        "path": {
          "type": "string",
          "description": "Path to log file. Default: \"log/trace.log\"",
          "default": "log/trace.log"
        },
        "level": {
          "type": "integer",
          "description": "Log level (0-255). Default: 0",
          "minimum": 0,
          "maximum": 255,
          "default": 0
        }
      },
      "additionalProperties": false
    },
    "server": {
      "type": "object",
      "description": "Server connection settings (mandatory)",
      "properties": {
        "ip": {
          "type": "string",
          "description": "Server IP address (mandatory)"
        },
        "port": {
          "type": "integer",
          "description": "Server port (mandatory, 0-65535)",
          "minimum": 0,
          "maximum": 65535
        }
      },
      "required": ["ip", "port"],
      "additionalProperties": false
    },
    "general": {
      "type": "object",
      "description": "General client settings (mandatory)",
      "properties": {
        "source": {
          "type": "string",
          "description": "Stream source (e.g., URL or file path) (mandatory)"
        },
        "port": {
          "type": "integer",
          "description": "Local port for receiving data. Default: 8000",
          "minimum": 0,
          "maximum": 65535,
          "default": 8000
        },
        "encoded": {
          "type": "boolean",
          "description": "Stream encoding mode. Default: false",
          "default": false
        }
      },
      "required": ["source"],
      "additionalProperties": false
    }
  },
  "required": ["server", "general"],
  "additionalProperties": false
}