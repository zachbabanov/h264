{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "description": "Server configuration",
  "properties": {
    "log": {
      "type": "object",
      "description": "Logging settings (optional)",
      "properties": {
        "path": {
          "type": "string",
          "description": "Path to log file. Default: \"log/trace.log\"",
          "default": "log/trace.log"
        },
        "level": {
          "type": "integer",
          "description": "Log level (0-255). Default: 0",
          "minimum": 0,
          "maximum": 255,
          "default": 0
        }
      },
      "additionalProperties": false
    },
    "statistics": {
      "type": "object",
      "description": "Statistics collection settings (optional)",
      "properties": {
        "path": {
          "type": "string",
          "description": "Path to statistics file. Default: \"log/statistics.log\"",
          "default": "log/statistics.log"
        },
        "counters": {
          "type": "array",
          "description": "List of counter names to register. Default: [\"acceptedPackets\", \"acceptedBlocks\", \"expectedBlocks\", \"assembledNalu\", \"skippedNalu\"]",
          "items": {
            "type": "string"
          },
          "default": ["acceptedPackets", "acceptedBlocks", "expectedBlocks", "assembledNalu", "skippedNalu"]
        }
      },
      "additionalProperties": false
    },
    "player": {
      "type": "object",
      "description": "Player/stream processing settings (optional)",
      "properties": {
        "bufferInterval": {
          "type": "integer",
          "description": "Buffer interval in milliseconds. Default: 33",
          "minimum": 0,
          "default": 33
        },
        "frameTimeout": {
          "type": "integer",
          "description": "Frame assembly timeout in milliseconds. Default: 100",
          "minimum": 0,
          "default": 100
        }
      },
      "additionalProperties": false
    },
    "general": {
      "type": "object",
      "description": "General server settings (mandatory)",
      "properties": {
        "port": {
          "type": "integer",
          "description": "Server listening port (mandatory, 0-65535)",
          "minimum": 0,
          "maximum": 65535
        },
        "rxBufferSize": {
          "type": "integer",
          "description": "Socket receive buffer size in bytes. Default: 65536",
          "minimum": 0,
          "default": 65536
        }
      },
      "required": ["port"],
      "additionalProperties": false
    }
  },
  "required": ["general"],
  "additionalProperties": false
}